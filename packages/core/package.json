{
  "name": "@nacho-labs/angular-grab",
  "version": "0.1.2",
  "description": "Grab any element in your Angular app and give it to AI coding agents",
  "author": "Nate Richardson",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/core/index.cjs",
  "module": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "bin": {
    "angular-grab": "./dist/cli/index.js"
  },
  "builders": "./builders.json",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./global": "./dist/core/index.global.js",
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "import": "./dist/angular/index.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild-plugin/index.d.ts",
      "import": "./dist/esbuild-plugin/index.js",
      "require": "./dist/esbuild-plugin/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.js"
    },
    "./webpack": {
      "types": "./dist/webpack-plugin/index.d.ts",
      "import": "./dist/webpack-plugin/index.js",
      "require": "./dist/webpack-plugin/index.cjs"
    },
    "./webpack/loader": {
      "import": "./dist/webpack-plugin/loader.js",
      "require": "./dist/webpack-plugin/loader.cjs"
    },
    "./builder": {
      "require": "./dist/builder/index.js"
    },
    "./dist/builder/builders/application/index": "./dist/builder/builders/application/index.js",
    "./dist/builder/builders/dev-server/index": "./dist/builder/builders/dev-server/index.js",
    "./builders.json": "./builders.json",
    "./package.json": "./package.json"
  },
  "files": ["dist", "builders.json", "README.md"],
  "scripts": {
    "prebuild": "node -e \"require('fs').copyFileSync('../../README.md','README.md')\"",
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'),p=require('path');['application','dev-server'].forEach(b=>{const d=p.join('dist','builder','builders',b);fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p.join('src','builder','builders',b,'schema.json'),p.join(d,'schema.json'))});fs.writeFileSync(p.join('dist','builder','package.json'),'{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "node -e \"const fs=require('fs');['dist','README.md'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch{}})\""
  },
  "peerDependencies": {
    "@angular/core": ">=19.0.0",
    "@angular/build": ">=18.0.0",
    "@angular-devkit/architect": ">=0.1800.0",
    "esbuild": ">=0.17.0",
    "typescript": ">=5.0.0",
    "vite": ">=5.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": { "optional": true },
    "@angular/build": { "optional": true },
    "@angular-devkit/architect": { "optional": true },
    "esbuild": { "optional": true },
    "vite": { "optional": true },
    "webpack": { "optional": true }
  },
  "devDependencies": {
    "@angular/core": "^21.0.0",
    "@angular/build": "^21.1.1",
    "@angular-devkit/architect": "^0.2101.1",
    "esbuild": "^0.21.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nacho-labs-llc/angular-grab.git",
    "directory": "packages/core"
  },
  "homepage": "https://angular-grab.com",
  "bugs": "https://github.com/nacho-labs-llc/angular-grab/issues",
  "keywords": ["angular", "angular-grab", "nacho-labs", "element-picker", "developer-tools", "ai", "esbuild", "vite", "webpack"]
}
